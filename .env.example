# Flask Configuration
SESSION_SECRET=your-secret-key-here-change-in-production
FLASK_ENV=production

# Database Configuration
# For SQLite (default):
DATABASE_URL=sqlite:////var/www/Sajborg/instance/pcshop.db
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://username:password@localhost/sajborg_db
# For MySQL:
# DATABASE_URL=mysql://username:password@localhost/sajborg_db

# Stripe Payment Configuration
# Test keys (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Email Configuration (Optional - for future email functionality)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=no-reply@sajborg.com

# Application Configuration
DEBUG=false
# Set to 'false' in production!

# Security
# In production, set SESSION_COOKIE_SECURE=true if using HTTPS
SESSION_COOKIE_SECURE=true

# File Upload Configuration
MAX_UPLOAD_SIZE=5242880  # 5MB in bytes

# Rate Limiting (Optional - for future implementation)
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URL=memory://

# Sentry Error Tracking (Optional - for production monitoring)
# SENTRY_DSN=your-sentry-dsn-here
