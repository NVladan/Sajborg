[run]
omit =
    */venv/*
    */migrations/*
    */tests/*
    */__pycache__/*
    */site-packages/*
    env_validator.py
    config.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
